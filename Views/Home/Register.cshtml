@{
    ViewData["Title"] = "Register";
}

<style>
    .login-page {
        background: #fff9db;
        border: 1px solid #f1e6a8;
        padding: 24px;
        color: #222;
    }

    .login-panel {
        background: #ffffff;
        border: 1px solid #eadf9b;
        padding: 24px;
        max-width: 460px;
        margin: 24px auto;
    }

    .login-title {
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .login-subtitle {
        color: #666;
        margin-bottom: 20px;
    }

    .findyou-brand {
        color: #8a6d00;
        font-weight: 700;
    }

    .btn,
    .form-control {
        border-radius: 0 !important;
    }

    .field-error {
        color: #dc3545;
        display: none;
        font-size: 14px;
        margin-top: 6px;
    }

    .form-control.is-invalid {
        border-color: #dc3545;
        box-shadow: none;
    }

    .login-link {
        color: #8a6d00;
        font-weight: 600;
        text-decoration: none;
    }

    .login-link:hover {
        color: #6f5700;
        text-decoration: underline;
    }
</style>

<div class="login-page">
    <div class="login-panel">
        <p class="mb-1 findyou-brand">FindYOU</p>
        <h1 class="login-title">Register</h1>
        <p class="login-subtitle">Create your account to start managing FindYOU records.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger rounded-0">@ViewBag.Error</div>
        }

        <form asp-controller="Home" asp-action="Register" method="post" id="registerForm" novalidate>
            <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <input type="text" id="name" name="Name" class="form-control" placeholder="Enter name" autocomplete="name" />
                <div class="field-error" id="nameError">Name is required.</div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="Email" class="form-control" placeholder="Enter email" autocomplete="email" />
                <div class="field-error" id="emailError">Enter a valid email address.</div>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" autocomplete="new-password" />
                <div class="field-error" id="passwordError">
                    Password must be at least 6 characters and include one lowercase letter, one uppercase letter, and one special character.
                </div>
            </div>

            <button type="submit" class="btn btn-warning text-dark w-100">Register</button>
        </form>

        <p class="mb-0 mt-3 text-center">
            Already have an account?
            <a asp-controller="Home" asp-action="Login" class="login-link">Login</a>
        </p>
    </div>
</div>

<script>
    (function () {
        const form = document.getElementById("registerForm");
        const nameInput = document.getElementById("name");
        const emailInput = document.getElementById("email");
        const passwordInput = document.getElementById("password");

        const emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        const passwordPattern = /^(?=.*[a-z])(?=.*[A-Z])(?=.*[^A-Za-z0-9]).{6,}$/;

        function setFieldState(input, errorId, isValid) {
            const error = document.getElementById(errorId);

            input.classList.toggle("is-invalid", !isValid);
            error.style.display = isValid ? "none" : "block";

            return isValid;
        }

        function validateName() {
            return setFieldState(nameInput, "nameError", nameInput.value.trim().length > 0);
        }

        function validateEmail() {
            return setFieldState(emailInput, "emailError", emailPattern.test(emailInput.value.trim()));
        }

        function validatePassword() {
            return setFieldState(passwordInput, "passwordError", passwordPattern.test(passwordInput.value));
        }

        nameInput.addEventListener("input", validateName);
        emailInput.addEventListener("input", validateEmail);
        passwordInput.addEventListener("input", validatePassword);

        form.addEventListener("submit", function (event) {
            const isValid = validateName() & validateEmail() & validatePassword();

            if (!isValid) {
                event.preventDefault();
            }
        });
    })();
</script>
