@{
    ViewData["Title"] = "Register";
}

<style>
    .login-page {
        background: #fff9db;
        border: 1px solid #f1e6a8;
        padding: 24px;
        color: #222;
    }

    .login-panel {
        background: #ffffff;
        border: 1px solid #eadf9b;
        padding: 24px;
        max-width: 680px;
        margin: 24px auto;
    }

    .login-title {
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .login-subtitle {
        color: #666;
        margin-bottom: 20px;
    }

    .findyou-brand {
        color: #8a6d00;
        font-weight: 700;
    }

    .btn,
    .form-control {
        border-radius: 0 !important;
    }

    .field-error {
        color: #dc3545;
        display: none;
        font-size: 14px;
        margin-top: 6px;
    }

    .form-control.is-invalid {
        border-color: #dc3545;
        box-shadow: none;
    }

    .tag-options {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
        margin-top: 10px;
    }

    .tag-option {
        border: 1px solid #ddd;
        padding: 8px 10px;
        cursor: pointer;
        background: #fff;
    }

    .tag-option.selected {
        border-color: #d39e00;
        background: #fff3cd;
    }

    .tag-option.disabled {
        cursor: not-allowed;
        opacity: .55;
    }

    .tag-option input {
        margin-right: 6px;
    }

    .selected-tags {
        color: #666;
        font-size: 13px;
        margin-top: 8px;
        min-height: 20px;
    }

    @@media (max-width: 576px) {
        .tag-options {
            grid-template-columns: 1fr;
        }
    }

    .login-link {
        color: #8a6d00;
        font-weight: 600;
        text-decoration: none;
    }

    .login-link:hover {
        color: #6f5700;
        text-decoration: underline;
    }
</style>

<div class="login-page">
    <div class="login-panel">
        <p class="mb-1 findyou-brand">FindYOU</p>
        <h1 class="login-title">Register</h1>
        <p class="login-subtitle">Create your account to start managing FindYOU records.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger rounded-0">@ViewBag.Error</div>
        }

        <form asp-controller="Home" asp-action="Register" method="post" id="registerForm" novalidate>
            <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <input type="text" id="name" name="Name" class="form-control" placeholder="Enter name" autocomplete="name" />
                <div class="field-error" id="nameError">Name is required.</div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="Email" class="form-control" placeholder="Enter email" autocomplete="email" />
                <div class="field-error" id="emailError">Enter a valid email address.</div>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" autocomplete="new-password" />
                <div class="field-error" id="passwordError">
                    Password must be at least 6 characters and include one lowercase letter, one uppercase letter, and one special character.
                </div>
            </div>

            <div class="mb-3">
                <label for="interestCategory" class="form-label">Interest field</label>
                <select id="interestCategory" class="form-control">
                    <option value="">Select a field</option>
                </select>
            </div>

            <div class="mb-3" id="tagSection" hidden>
                <div class="d-flex justify-content-between align-items-center">
                    <label class="form-label mb-0">Select your tags</label>
                    <small id="tagCount" class="text-muted">0 / 20 selected</small>
                </div>
                <div id="tagOptions" class="tag-options"></div>
                <div id="selectedTagsSummary" class="selected-tags"></div>
                <div class="field-error" id="interestTagsError">Select at least 3 and no more than 20 tags.</div>
            </div>

            <input type="hidden" id="interestTags" name="InterestTags" />

            <button type="submit" class="btn btn-warning text-dark w-100">Register</button>
        </form>

        <p class="mb-0 mt-3 text-center">
            Already have an account?
            <a asp-controller="Home" asp-action="Login" class="login-link">Login</a>
        </p>
    </div>
</div>

<script>
    (function () {
        const form = document.getElementById("registerForm");
        const nameInput = document.getElementById("name");
        const emailInput = document.getElementById("email");
        const passwordInput = document.getElementById("password");
        const categoryInput = document.getElementById("interestCategory");
        const tagSection = document.getElementById("tagSection");
        const tagOptions = document.getElementById("tagOptions");
        const tagCount = document.getElementById("tagCount");
        const selectedTagsSummary = document.getElementById("selectedTagsSummary");
        const interestTagsInput = document.getElementById("interestTags");
        const interestTagsError = document.getElementById("interestTagsError");

        const interestData = {
            "Technology & Programming": ["Programming", "Backend Development", "Frontend Development", "Full Stack Development", "Mobile Development", "Database", "Cloud Computing", "DevOps", "Cyber Security", "Artificial Intelligence", "Machine Learning", "System Design", "Open Source"],
            "Engineering": ["Computer Engineering", "Mechanical Engineering", "Civil Engineering", "Electrical Engineering", "Electronics", "Robotics", "Automation", "CAD Design", "Manufacturing", "Industrial Engineering"],
            "Science": ["Physics", "Chemistry", "Biology", "Astronomy", "Environmental Science", "Research", "Laboratory Work", "Biotechnology"],
            "Mathematics": ["Algebra", "Calculus", "Statistics", "Probability", "Geometry", "Data Analysis", "Quantitative Reasoning"],
            "Commerce & Finance": ["Accounting", "Taxation", "GST", "Banking", "Investment", "Stock Market", "Financial Planning", "Auditing", "Economics"],
            "Business & Entrepreneurship": ["Startups", "Business Strategy", "Leadership", "Management", "Operations", "Product Management", "Entrepreneurship", "Consulting"],
            "Law": ["Corporate Law", "Civil Law", "Criminal Law", "Contracts", "Cyber Law", "Legal Research", "Compliance"],
            "Medical & Healthcare": ["Medicine", "Nursing", "Public Health", "Nutrition", "Mental Wellness", "Clinical Research", "Healthcare Management"],
            "Education & Teaching": ["Teaching", "Online Learning", "Exam Preparation", "Career Guidance", "Training", "Skill Development"],
            "Arts & Design": ["Graphic Design", "UI UX Design", "Illustration", "Animation", "Digital Art", "Brand Design"],
            "Writing & Content Creation": ["Blogging", "Technical Writing", "Copywriting", "Story Writing", "Public Speaking", "Content Creation", "Podcasting"],
            "Marketing & Sales": ["Digital Marketing", "SEO", "Social Media Marketing", "Email Marketing", "Branding", "Advertising", "Sales", "Lead Generation"],
            "Data & Analytics": ["SQL", "Power BI", "Tableau", "Excel", "Business Analytics", "Data Engineering", "Big Data", "Reporting"],
            "Sports & Fitness": ["Gym", "Bodybuilding", "Running", "Cricket", "Football", "Badminton", "Yoga", "Nutrition", "Weight Loss"],
            "Music & Entertainment": ["Singing", "Music Production", "Guitar", "Piano", "Movies", "TV Series", "Dance"],
            "Photography & Videography": ["Photography", "Video Editing", "Cinematography", "Drone Photography", "Photo Editing", "YouTube Creation"],
            "Travel & Tourism": ["Travel Planning", "Backpacking", "Road Trips", "Adventure Travel", "International Travel", "Local Exploration"],
            "Gaming & Esports": ["PC Gaming", "Mobile Gaming", "Esports", "Game Development", "Streaming", "Content Creation"],
            "Personal Development": ["Productivity", "Communication Skills", "Leadership", "Time Management", "Public Speaking", "Networking", "Self Improvement"],
            "Myself & Personal Life": ["Career Growth", "Job Search", "Relationships", "Family", "Lifestyle", "Daily Routine", "Goal Setting", "Personal Finance", "Mental Wellness", "Life Planning", "Motivation"]
        };

        const selectedTags = new Set();

        const emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        const passwordPattern = /^(?=.*[a-z])(?=.*[A-Z])(?=.*[^A-Za-z0-9]).{6,}$/;

        function setFieldState(input, errorId, isValid) {
            const error = document.getElementById(errorId);

            input.classList.toggle("is-invalid", !isValid);
            error.style.display = isValid ? "none" : "block";

            return isValid;
        }

        function validateName() {
            return setFieldState(nameInput, "nameError", nameInput.value.trim().length > 0);
        }

        function validateEmail() {
            return setFieldState(emailInput, "emailError", emailPattern.test(emailInput.value.trim()));
        }

        function validatePassword() {
            return setFieldState(passwordInput, "passwordError", passwordPattern.test(passwordInput.value));
        }

        function validateInterestTags() {
            const isValid = selectedTags.size >= 3 && selectedTags.size <= 20;
            interestTagsError.style.display = isValid ? "none" : "block";
            return isValid;
        }

        function updateSelectedTags() {
            const tags = Array.from(selectedTags);

            // The category select has no name, so only this existing User property is posted.
            interestTagsInput.value = tags.join(" ");
            tagCount.textContent = `${tags.length} / 20 selected`;
            selectedTagsSummary.textContent = tags.length > 0
                ? `Selected: ${tags.join(", ")}`
                : "No tags selected yet.";
        }

        function renderTags() {
            const tags = interestData[categoryInput.value] || [];
            tagOptions.replaceChildren();
            tagSection.hidden = tags.length === 0;

            tags.forEach(function (tag) {
                const label = document.createElement("label");
                const checkbox = document.createElement("input");
                const isSelected = selectedTags.has(tag);
                const isDisabled = !isSelected && selectedTags.size >= 20;

                label.className = `tag-option${isSelected ? " selected" : ""}${isDisabled ? " disabled" : ""}`;
                checkbox.type = "checkbox";
                checkbox.checked = isSelected;
                checkbox.disabled = isDisabled;

                checkbox.addEventListener("change", function () {
                    if (checkbox.checked && selectedTags.size < 20) {
                        selectedTags.add(tag);
                    } else {
                        selectedTags.delete(tag);
                    }

                    updateSelectedTags();
                    renderTags();
                    validateInterestTags();
                });

                label.append(checkbox, document.createTextNode(tag));
                tagOptions.appendChild(label);
            });
        }

        Object.keys(interestData).forEach(function (category) {
            const option = document.createElement("option");
            option.value = category;
            option.textContent = category;
            categoryInput.appendChild(option);
        });

        nameInput.addEventListener("input", validateName);
        emailInput.addEventListener("input", validateEmail);
        passwordInput.addEventListener("input", validatePassword);
        categoryInput.addEventListener("change", renderTags);
        updateSelectedTags();

        form.addEventListener("submit", function (event) {
            const isValid = validateName() & validateEmail() & validatePassword() & validateInterestTags();

            if (!isValid) {
                event.preventDefault();
            }
        });
    })();
</script>
